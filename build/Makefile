.PHONY : tune_test

# fast build rule for target.
tune_test/fast:
	$(MAKE) $(MAKESILENT) -f tests/CMakeFiles/tune_test.dir/build.make tests/CMakeFiles/tune_test.dir/build
.PHONY : tune_test/fast

