@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

set(GGP_QMP @GGP_QMP@)
set(GGP_MPI @GGP_MPI@)
set(GGP_QIO @GGP_QIO@)
set(GGP_OPENMP @GGP_OPENMP@)
set(GGP_QDPJIT @GGP_QDPJIT@)
set(GGP_GITVERSION @GITVERSION@)
set(GGP_PRECISION @GGP_PRECISION@)
set(GGP_RECONSTRUCT @GGP_RECONSTRUCT@)

set(GGP_TARGET_CUDA @GGP_TARGET_CUDA@)
set(GGP_TARGET_HIP  @GGP_TARGET_HIP@)

set(GGP_NVSHMEM  @GGP_NVSHMEM@)

if( GGP_QMP AND GGP_MPI )
  message(FATAL_ERROR "Cannot have both QMP and MPI configured")  
endif()

# Everyone needs this
find_dependency(Threads REQUIRED)

if( GGP_QMP )
  find_dependency(QMP REQUIRED)
endif()

if( GGP_MPI )
  find_dependency(MPI REQUIRED)
endif()

if( GGP_QIO )
  find_dependency(QIO REQUIRED)
endif()

if( GGP_OPENMP )
  find_dependency(OpenMP REQUIRED)
endif()

if( GGP_TARGET_CUDA )
  include(${CMAKE_CURRENT_LIST_DIR}/find_target_cuda_dependencies.cmake)
elseif(GGP_TARGET_HIP )
  include(${CMAKE_CURRENT_LIST_DIR}/find_target_hip_dependencies.cmake )
endif()

if( GGP_QDPJIT )
  find_dependency( QDPXX REQUIRED )
endif()

include(${CMAKE_CURRENT_LIST_DIR}/GGPTargets.cmake)


